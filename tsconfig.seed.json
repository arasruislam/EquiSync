{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "./.seed-dist",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src/scripts/**/*.ts", "src/models/**/*.ts", "src/lib/**/*.ts"],
  "exclude": ["node_modules"]
}
